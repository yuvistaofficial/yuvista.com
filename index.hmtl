<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Yuvista</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial;
}

body{
background:#0f0f0f;
color:white;
padding-top:65px;
padding-bottom:75px;
}

/* TOP BAR */

.topbar{
position:fixed;
top:0;
left:0;
width:100%;
height:60px;
background:#0f0f0f;
display:flex;
align-items:center;
justify-content:space-between;
padding:0 15px;
z-index:1000;
border-bottom:1px solid #222;
}

.logo{
display:flex;
align-items:center;
gap:8px;
}

.logo-icon{
width:32px;
height:22px;
background:red;
border-radius:6px;
display:flex;
align-items:center;
justify-content:center;
font-size:14px;
}

.logo-text{
font-size:22px;
font-weight:bold;
}

.top-icons{
display:flex;
align-items:center;
gap:18px;
font-size:24px;
}

.profile{
width:34px;
height:34px;
border-radius:50%;
object-fit:cover;
}

/* CATEGORY */

.category-bar{
display:flex;
overflow-x:auto;
padding:12px 10px;
gap:10px;
background:#0f0f0f;
position:sticky;
top:60px;
z-index:999;
}

.category-bar::-webkit-scrollbar{
display:none;
}

.category{
background:#272727;
padding:8px 14px;
border-radius:10px;
white-space:nowrap;
font-size:14px;
}

.active-category{
background:white;
color:black;
}

/* VIDEOS */

.video{
margin-bottom:25px;
}

.thumbnail{
width:100%;
height:230px;
object-fit:cover;
}

.video-info{
display:flex;
padding:10px;
gap:10px;
}

.channel-pic{
width:42px;
height:42px;
border-radius:50%;
object-fit:cover;
}

.video-text{
flex:1;
}

.video-title{
font-size:16px;
font-weight:bold;
line-height:22px;
margin-bottom:5px;
}

.video-details{
font-size:13px;
color:#aaa;
line-height:20px;
}

/* BOTTOM NAV */

.bottom-nav{
position:fixed;
bottom:0;
left:0;
width:100%;
height:65px;
background:#0f0f0f;
display:flex;
justify-content:space-around;
align-items:center;
border-top:1px solid #222;
z-index:1000;
}

.nav-item{
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
font-size:11px;
color:white;
}

.nav-icon{
font-size:24px;
margin-bottom:2px;
}

.plus-btn{
width:42px;
height:42px;
background:white;
color:black;
border-radius:50%;
display:flex;
align-items:center;
justify-content:center;
font-size:28px;
font-weight:bold;
}

</style>
</head>

<body>

<!-- TOP BAR -->

<div class="topbar">

<div class="logo">
<div class="logo-icon">▶</div>
<div class="logo-text">Yuvista</div>
</div>

<div class="top-icons">
<div>📺</div>
<div>🔔</div>
<div>🔍</div>
<img src="https://i.pravatar.cc/100" class="profile">
</div>

</div>

<!-- CATEGORY -->

<div class="category-bar">

<div class="category active-category">All</div>
<div class="category">Music</div>
<div class="category">Gaming</div>
<div class="category">Live</div>
<div class="category">News</div>
<div class="category">Movies</div>
<div class="category">Cricket</div>
<div class="category">Trending</div>
<div class="category">Coding</div>

</div>

<!-- VIDEOS -->

<div class="video">

<img src="https://picsum.photos/700/400?1" class="thumbnail">

<div class="video-info">

<img src="https://i.pravatar.cc/100?1" class="channel-pic">

<div class="video-text">

<div class="video-title">
Amazing Nature Cinematic Video 4K
</div>

<div class="video-details">
Nature Studio • 2M views • 2 days ago
</div>

</div>

<div>⋮</div>

</div>

</div>

<div class="video">

<img src="https://picsum.photos/700/400?2" class="thumbnail">

<div class="video-info">

<img src="https://i.pravatar.cc/100?2" class="channel-pic">

<div class="video-text">

<div class="video-title">
Gaming Live Stream Battle Royale
</div>

<div class="video-details">
Gaming Pro • 950K views • Live now
</div>

</div>

<div>⋮</div>

</div>

</div>

<div class="video">

<img src="https://picsum.photos/700/400?3" class="thumbnail">

<div class="video-info">

<img src="https://i.pravatar.cc/100?3" class="channel-pic">

<div class="video-text">

<div class="video-title">
Top Coding Tricks For Beginners
</div>

<div class="video-details">
Code Master • 500K views • 1 week ago
</div>

</div>

<div>⋮</div>

</div>

</div>

<div class="video">

<img src="https://picsum.photos/700/400?4" class="thumbnail">

<div class="video-info">

<img src="https://i.pravatar.cc/100?4" class="channel-pic">

<div class="video-text">

<div class="video-title">
Travel Vlog In Mountains Full HD
</div>

<div class="video-details">
Travel World • 800K views • 3 days ago
</div>

</div>

<div>⋮</div>

</div>

</div>

<!-- BOTTOM NAV -->

<div class="bottom-nav">

<div class="nav-item">
<div class="nav-icon">🏠</div>
<div>Home</div>
</div>

<div class="nav-item">
<div class="nav-icon">🎬</div>
<div>Shorts</div>
</div>

<div class="nav-item">
<div class="plus-btn">+</div>
</div>

<div class="nav-item">
<div class="nav-icon">🔔</div>
<div>Subscriptions</div>
</div>

<div class="nav-item">
<div class="nav-icon">👤</div>
<div>You</div>
</div>

</div>

</body>
</html>
